---
/* Publications list — hydrated at build time from data/publications.json.
 * The daily GitHub Actions workflow regenerates the JSON; any commit to
 * main rebuilds the site with fresh entries. No runtime fetch needed.
 */
import pubsData from "../../data/publications.json";

type Pub = {
  id?: string;
  title: string;
  authors?: string;
  venue?: string;
  details?: string;
  year?: number;
  doi?: string;
  url?: string;
  role?: "first" | "co" | string;
  type?: string;
};

const publications = (pubsData.publications as Pub[]).slice().sort(
  (a, b) => (b.year || 0) - (a.year || 0),
);
const generatedAt = pubsData.generated_at ?? "";

const AUTHOR_RE = /(L\.\s*R\.\s*Mercado[-\s]?D[ií]az|Luis\s+R\.?\s*Mercado[-\s]?D[ií]az|Luis\s+Roberto\s+Mercado\s+D[ií]az)/gi;

function highlightAuthor(authors = ""): string {
  const esc = authors
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
  return esc.replace(AUTHOR_RE, '<span class="font-semibold text-slate-800 dark:text-slate-200">$&</span>');
}
---
<section id="publications" class="py-20 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="mb-12 fade-in">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4">
      <div>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Publications</h2>
        <div class="w-20 h-1 bg-primary rounded-full"></div>
      </div>
      <p class="text-xs text-slate-500 dark:text-slate-400 max-w-md md:text-right">
        Auto-synced daily from
        <a href="https://openalex.org" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">OpenAlex</a>
        (with
        <a href="https://www.crossref.org" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">CrossRef</a>
        fallback). Last refresh: <span class="font-mono">{generatedAt}</span>.
      </p>
    </div>

    <div class="flex flex-wrap gap-3 mb-8">
      <button class="pub-filter active px-4 py-2 rounded-full text-sm font-medium transition-colors" data-filter="all">All Publications</button>
      <button class="pub-filter px-4 py-2 rounded-full text-sm font-medium transition-colors" data-filter="first">First / Co-First Author</button>
      <button class="pub-filter px-4 py-2 rounded-full text-sm font-medium transition-colors" data-filter="co">Co-Author</button>
      <div class="flex-1 min-w-[12rem] md:max-w-sm ml-auto">
        <label for="pub-search" class="sr-only">Search publications</label>
        <div class="relative">
          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
          <input id="pub-search" type="search" placeholder="Search title, venue, DOI…"
                 class="w-full pl-8 pr-3 py-2 text-sm rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-darkCard focus:outline-none focus:ring-2 focus:ring-primary/40"
                 autocomplete="off" />
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-6" id="publications-list">
    {publications.map((p) => (
      <article class={`pub-item ${p.role === "first" ? "first" : "co"} p-6 bg-white dark:bg-darkCard rounded-lg shadow-sm border-l-4 ${p.role === "first" ? "border-primary" : "border-slate-300 dark:border-slate-600"} hover:shadow-md transition-shadow`}>
        <div class="mb-2">
          {p.year && (
            <span class="inline-block px-2 py-0.5 text-[10px] font-bold rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 mr-2">{p.year}</span>
          )}
          {p.role === "first" ? (
            <span class="inline-block px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-full bg-primary/10 text-primary">First / Co-First</span>
          ) : (
            <span class="inline-block px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-full bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300">Co-Author</span>
          )}
        </div>
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2 leading-snug">{p.title}</h3>
        <p class="text-slate-600 dark:text-slate-400 text-sm mb-2" set:html={highlightAuthor(p.authors)}></p>
        <p class="text-sm italic text-slate-500 dark:text-slate-500 mb-3">{p.details || p.venue || ""}</p>
        {p.doi && (
          <a href={p.url || `https://doi.org/${p.doi}`} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center text-sm text-primary hover:text-secondary hover:underline">
            <i class="fas fa-external-link-alt mr-1 text-xs"></i> DOI: {p.doi}
          </a>
        )}
      </article>
    ))}
  </div>
</section>

<script>
  // Publications client behaviour — filter + search. The data is fully
  // static (rendered by the server), so we only toggle visibility here.
  document.addEventListener("DOMContentLoaded", () => {
    const items = Array.from(document.querySelectorAll<HTMLElement>(".pub-item"));
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>(".pub-filter"));
    const search = document.querySelector<HTMLInputElement>("#pub-search");

    let currentFilter = "all";
    let query = "";

    const apply = () => {
      const q = query.trim().toLowerCase();
      for (const it of items) {
        const roleOk = currentFilter === "all" || it.classList.contains(currentFilter);
        const hay = (it.textContent || "").toLowerCase();
        const searchOk = !q || hay.includes(q);
        it.style.display = roleOk && searchOk ? "block" : "none";
      }
    };

    filters.forEach((b) => b.addEventListener("click", () => {
      filters.forEach((x) => x.classList.remove("active"));
      b.classList.add("active");
      currentFilter = b.dataset.filter || "all";
      apply();
    }));
    search?.addEventListener("input", (e) => {
      query = (e.target as HTMLInputElement).value;
      apply();
    });
  });
</script>
