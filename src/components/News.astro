---
import { news } from "../data/news";
---
<section id="news" class="py-20 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="mb-12 fade-in">
    <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Recent News</h2>
    <div class="w-20 h-1 bg-primary rounded-full"></div>
  </div>

  <div class="bg-white dark:bg-darkCard rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden">
    <div class="max-h-96 overflow-y-auto custom-scrollbar p-6 space-y-6">
      {news.map((n) => (
        <div class="news-item flex gap-4 fade-in">
          <div class="text-primary font-bold whitespace-nowrap text-sm mt-0.5">{n.date}</div>
          <div class="text-sm text-slate-700 dark:text-slate-300">
            {n.headline && (
              n.kind === "story"
                ? <span class="font-semibold block text-lg mb-2">{n.headline}</span>
                : <span class="font-semibold">{n.headline}:</span>
            )}
            {" " + n.body}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
