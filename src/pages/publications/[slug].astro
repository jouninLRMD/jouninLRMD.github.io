---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { allPublications, pubSlug, type Publication } from "../../lib/publications";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const pubs = allPublications();
  return pubs.map((p) => ({
    params: { slug: pubSlug(p) },
    props: { publication: p },
  }));
}

interface Props {
  publication: Publication;
}

const { publication: p } = Astro.props;
const canonical = p.url || (p.doi ? `https://doi.org/${p.doi}` : undefined);
const pageTitle = `${p.title} — ${site.name}`;
const pageDescription =
  `${p.authors ?? site.name}${p.details ? ` — ${p.details}` : p.venue ? ` — ${p.venue}` : ""}`;
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <a href="/#publications" class="text-sm text-primary hover:underline">&larr; All publications</a>

    <article class="mt-6">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        {p.year && (
          <span class="inline-block px-2 py-0.5 text-[10px] font-bold rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">{p.year}</span>
        )}
        {p.role === "first" ? (
          <span class="inline-block px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-full bg-primary/10 text-primary">First / Co-First</span>
        ) : (
          <span class="inline-block px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-full bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300">Co-Author</span>
        )}
        {p.type && (
          <span class="inline-block px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide rounded-full bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400">{p.type}</span>
        )}
      </div>

      <h1 class="text-3xl font-bold text-slate-900 dark:text-white leading-tight">{p.title}</h1>
      {p.authors && <p class="text-slate-600 dark:text-slate-400 mt-3">{p.authors}</p>}
      {p.details && <p class="text-sm italic text-slate-500 dark:text-slate-400 mt-1">{p.details}</p>}

      <dl class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
        {p.venue && (<div><dt class="font-semibold text-slate-900 dark:text-white">Venue</dt><dd class="text-slate-600 dark:text-slate-400">{p.venue}</dd></div>)}
        {p.doi && (<div><dt class="font-semibold text-slate-900 dark:text-white">DOI</dt><dd class="text-slate-600 dark:text-slate-400 font-mono break-all">{p.doi}</dd></div>)}
        {p.source && (<div><dt class="font-semibold text-slate-900 dark:text-white">Source</dt><dd class="text-slate-600 dark:text-slate-400">{p.source}</dd></div>)}
      </dl>

      {canonical && (
        <div class="mt-8">
          <a href={canonical} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:bg-secondary transition-colors">
            <i class="fas fa-external-link-alt mr-2"></i>Read the paper
          </a>
        </div>
      )}

      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ScholarlyArticle",
        headline: p.title,
        author: (p.authors || site.name).split(/,\s*/).map((n) => ({ "@type": "Person", name: n })),
        datePublished: p.year ? String(p.year) : undefined,
        isPartOf: p.venue ? { "@type": "Periodical", name: p.venue } : undefined,
        identifier: p.doi ? { "@type": "PropertyValue", propertyID: "doi", value: p.doi } : undefined,
        url: canonical,
      })} />
    </article>
  </main>
</BaseLayout>
